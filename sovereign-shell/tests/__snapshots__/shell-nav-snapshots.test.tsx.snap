            style="margin: 0px; font-size: 13px; font-weight: 700; color: rgb(15, 23, 42);"
          >
            Things to Do
          </h2>
          <span
            style="margin: 0px; font-size: 12px; color: rgb(100, 116, 139);"
          >
            Cross-product · current state
          </span>
        </div>
        <ul
          style="margin: 0px; padding: 0px; list-style: none; display: flex; flex-direction: column; gap: 6px;"
        >
          <li
            style="display: flex; align-items: flex-start; gap: 8px; font-size: 12px; padding: 6px 10px; border-radius: 6px; background: rgb(240, 253, 244); color: rgb(22, 101, 52);"
          >
            <span
              aria-hidden="true"
              style="width: 8px; height: 8px; border-radius: 50%; background: rgb(22, 163, 74); flex-shrink: 0; margin-top: 3px;"
            />
            No actions required — all products GREEN
          </li>
        </ul>
      </section>
    </div>
  </div>
</div>
`;
