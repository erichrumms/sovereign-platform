{
  "name": "@sovereign/module-apex",
  "version": "1.0.0",
  "description": "SOVEREIGN Platform — APEX module (Analytics and Program Executive Suite — defensible, exportable analytics over CPMI/AgentOS outputs)",
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@sovereign/api-client": "^1.0.0",
    "@sovereign/data": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "jest": "^29.5.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts",
      "**/tests/**/*.test.tsx"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup-dom.ts"
    ],
    "moduleNameMapper": {
      "^(.+\\.md)\\?raw$": "$1",
      "(.*)/anthropic-key$": "<rootDir>/tests/__mocks__/anthropic-key.ts"
    },
    "transform": {
      "^.+\\.md$": "<rootDir>/tests/raw-transformer.cjs",
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "module": "commonjs",
            "moduleResolution": "node",
            "jsx": "react-jsx",
            "esModuleInterop": true,
            "isolatedModules": true,
            "skipLibCheck": true,
            "strict": true
          }
        }
      ]
    }
  }
}
